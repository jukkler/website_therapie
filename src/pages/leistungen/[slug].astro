---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import CTABanner from '@components/home/CTABanner.astro';

export async function getStaticPaths() {
  const leistungen = await getCollection('leistungen');
  return leistungen.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/leistungen/*.{jpg,jpeg,JPG,png,webp}',
  { eager: true }
);

function getImage(filename: string): ImageMetadata | undefined {
  const key = `/src/assets/leistungen/${filename}`;
  return imageModules[key]?.default;
}

const image = getImage(entry.data.image);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <!-- Page Header -->
  <section class="pt-32 pb-12 bg-surface-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a
        href="/leistungen/"
        class="inline-flex items-center gap-1 text-sm text-brand-muted hover:text-brand-primary transition-colors mb-6"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Alle Leistungen
      </a>
      <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark leading-tight">
        {entry.data.title}
      </h1>
      <p class="mt-4 text-lg text-brand-muted">
        {entry.data.description}
      </p>
    </div>
  </section>

  <!-- Hero Image -->
  {image && (
    <section class="bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl overflow-hidden shadow-md">
          <Image
            src={image}
            alt={entry.data.title}
            width={800}
            height={450}
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      </div>
    </section>
  )}

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none text-brand-muted prose-headings:text-brand-dark prose-headings:font-serif prose-li:marker:text-brand-primary">
        <Content />
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
