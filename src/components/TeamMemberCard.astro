---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  role: string;
  description: string;
  imageSrc?: ImageMetadata;
}

const { name, role, description, imageSrc } = Astro.props;
---

<div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-surface-light/30 text-center">
  <div class="aspect-[3/4] overflow-hidden bg-surface-bg">
    {imageSrc ? (
      <Image
        src={imageSrc}
        alt={`${name} – ${role}`}
        width={450}
        height={600}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-surface-light/20">
        <svg class="w-24 h-24 text-brand-muted/30" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
        </svg>
      </div>
    )}
  </div>
  <div class="p-6">
    <h3 class="font-serif text-xl font-bold text-brand-dark">{name}</h3>
    <p class="text-brand-primary font-medium text-sm mt-1">{role}</p>
    <p class="text-brand-muted text-sm mt-3 leading-relaxed">{description}</p>
  </div>
</div>
