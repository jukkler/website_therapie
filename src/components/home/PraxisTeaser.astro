---
import { Image } from 'astro:assets';
import Button from '@components/ui/Button.astro';

import imgPraxis1 from '@assets/praxis/door-neu.jpg';
import imgPraxis2 from '@assets/praxis/sauna-neu.jpg';

const features = [
  'Helle, modern ausgestattete Behandlungsräume',
  'Professionelle Geräte für Krankengymnastik',
  'Persönliche und individuelle Betreuung',
  'Wärme- und Wellnessbereich',
];
---

<section class="py-20 lg:py-28 bg-surface-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Images -->
      <div class="reveal-left grid grid-cols-2 gap-4">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <Image
            src={imgPraxis1}
            alt="Eingang Therapiezentrum Ziesemer"
            width={500}
            height={600}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg mt-8">
          <Image
            src={imgPraxis2}
            alt="Praxisräume Therapiezentrum Ziesemer"
            width={500}
            height={600}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="reveal-right text-center lg:text-left">
        <span class="inline-block text-sm font-semibold tracking-wide uppercase text-brand-primary mb-3">
          Unsere Praxis
        </span>
        <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-dark leading-tight">
          Wo <span class="text-brand-primary">Heilung</span> beginnt
        </h2>
        <p class="mt-6 text-brand-muted text-lg leading-relaxed">
          In unserer modern ausgestatteten Praxis in Witzhelden schaffen wir eine Atmosphäre,
          in der Sie sich wohlfühlen und optimal behandelt werden.
        </p>
        <ul class="mt-6 space-y-3 inline-block text-left">
          {features.map((feature) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-brand-muted">{feature}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8 flex justify-center lg:justify-start">
          <Button href="/praxis/" variant="secondary">
            Praxis entdecken
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
