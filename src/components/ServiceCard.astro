---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  imageSrc: ImageMetadata;
  href?: string;
}

const { title, description, imageSrc, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group flex flex-col h-full bg-white rounded-2xl overflow-hidden shadow-md border border-surface-light/30',
    'transition-all duration-200 hover:-translate-y-1 hover:shadow-xl',
    href && 'cursor-pointer',
  ]}
>
  <div class="aspect-[4/3] overflow-hidden">
    <Image
      src={imageSrc}
      alt={title}
      width={600}
      height={450}
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="p-6 flex-1">
    <h3 class="font-serif text-xl font-bold text-brand-dark mb-2">{title}</h3>
    <p class="text-brand-muted text-sm leading-relaxed">{description}</p>
  </div>
</Tag>
