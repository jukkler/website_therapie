---
import siteConfig from '@data/siteConfig.json';
import openingHours from '@data/openingHours.json';
---

<footer class="bg-brand-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 text-center md:text-left">
      <!-- Praxis Info -->
      <div>
        <h3 class="font-serif text-xl font-bold mb-4">{siteConfig.name}</h3>
        <p class="text-white/70 text-sm leading-relaxed mb-4">{siteConfig.tagline}</p>
        <address class="not-italic text-sm text-white/80 space-y-1">
          <p>{siteConfig.address.street}</p>
          <p>{siteConfig.address.zip} {siteConfig.address.city}</p>
        </address>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 class="font-serif text-lg font-bold mb-4">Kontakt</h3>
        <ul class="space-y-3 text-sm inline-block">
          <li>
            <a
              href={siteConfig.phoneHref}
              class="flex items-center gap-2 text-white/80 hover:text-white transition-colors"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${siteConfig.email}`}
              class="flex items-center gap-2 text-white/80 hover:text-white transition-colors"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {siteConfig.email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Öffnungszeiten -->
      <div>
        <h3 class="font-serif text-lg font-bold mb-4">Öffnungszeiten</h3>
        <dl class="space-y-1 text-sm inline-block">
          {openingHours.map((h) => (
            <div class="flex justify-between gap-4">
              <dt class="text-white/80 whitespace-nowrap">{h.day.slice(0, 2)}</dt>
              <dd class:list={['text-right whitespace-nowrap', h.open ? 'text-white/90' : 'text-white/50']}>
                {h.open ? h.hours.replace(' Uhr und ', ', ') : h.hours}
              </dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Quick Links + CTA -->
      <div>
        <h3 class="font-serif text-lg font-bold mb-4">Termin vereinbaren</h3>
        <p class="text-white/70 text-sm mb-4">
          Vereinbaren Sie jetzt Ihren Wunschtermin — bequem online oder telefonisch.
        </p>
        <a
          href="/termin-anfragen/"
          class="inline-flex items-center px-5 py-2.5 rounded-full bg-brand-primary text-white font-semibold text-sm hover:bg-white hover:text-brand-dark transition-all duration-200"
        >
          Termin anfragen
        </a>
        <nav class="mt-6 space-y-2 text-sm" aria-label="Footer Navigation">
          <a href="/impressum/" class="inline-block text-white/60 hover:text-white transition-colors">Impressum</a>
          <a href="/datenschutz/" class="inline-block text-white/60 hover:text-white transition-colors">Datenschutz</a>
          <button
            id="cookie-settings-btn"
            class="inline-block text-white/60 hover:text-white transition-colors cursor-pointer"
          >
            Cookie-Einstellungen
          </button>
        </nav>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-white/10 text-center text-sm text-white/50">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>
