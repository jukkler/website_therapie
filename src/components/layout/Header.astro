---
import siteConfig from '@data/siteConfig.json';

const navItems = [
  { label: 'Start', href: '/' },
  { label: 'Leistungen', href: '/leistungen/' },
  { label: 'Praxis', href: '/praxis/' },
  { label: 'Team', href: '/team/' },
  { label: 'Kontakt', href: '/kontakt/' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="sticky top-0 z-[70] bg-white/95 backdrop-blur-sm transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-3 items-center h-20 transition-all duration-300 header-inner">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group justify-self-start">
        <img
          src="/favicon.svg"
          alt=""
          class="w-10 h-10 transition-all duration-300 header-logo"
        />
        <span class="font-serif font-bold text-brand-dark text-lg sm:text-xl transition-all duration-300 header-title">
          {siteConfig.name}
        </span>
      </a>

      <!-- Desktop Navigation (centered) -->
      <nav class="hidden lg:flex items-center justify-center gap-1" aria-label="Hauptnavigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-4 py-2 rounded-full text-sm font-medium transition-colors',
              currentPath === item.href
                ? 'text-brand-primary bg-brand-primary/10'
                : 'text-brand-dark hover:text-brand-primary hover:bg-brand-primary/5',
            ]}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA + Mobile Menu Button -->
      <div class="flex items-center justify-self-end gap-3">
        <a
          href="/termin-anfragen/"
          class="hidden lg:inline-flex items-center px-6 py-2.5 rounded-full bg-brand-primary text-white font-semibold text-sm hover:bg-brand-dark hover:shadow-lg transition-all duration-200"
        >
          Termin anfragen
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-full text-brand-dark hover:bg-surface-bg transition-colors"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6 menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay (outside header to avoid sticky/fixed conflict) -->
<div
  id="mobile-menu"
  class="lg:hidden fixed inset-0 bg-white z-[65] translate-x-full transition-transform duration-300 ease-in-out overflow-y-auto"
  aria-hidden="true"
>
  <div class="h-20"></div>
  <nav class="flex flex-col p-6 gap-2" aria-label="Mobile Navigation">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'px-4 py-3 rounded-full text-lg font-medium transition-colors',
          currentPath === item.href
            ? 'text-brand-primary bg-brand-primary/10'
            : 'text-brand-dark hover:text-brand-primary hover:bg-surface-bg',
        ]}
        aria-current={currentPath === item.href ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
    <a
      href="/termin-anfragen/"
      class="mt-4 flex items-center justify-center px-6 py-3 rounded-full bg-brand-primary text-white font-semibold text-lg hover:bg-brand-dark transition-all duration-200"
    >
      Termin anfragen
    </a>
    <a
      href={siteConfig.phoneHref}
      class="flex items-center justify-center gap-2 px-6 py-3 rounded-full border-2 border-brand-primary text-brand-primary font-semibold text-lg hover:bg-brand-primary hover:text-white transition-all duration-200"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      {siteConfig.phone}
    </a>
  </nav>
</div>

<!-- Compact header styles -->
<style>
  .header--compact .header-inner {
    height: 3.5rem;
  }
  .header--compact .header-logo {
    width: 2rem;
    height: 2rem;
  }
  .header--compact .header-title {
    font-size: 1rem;
  }
  #site-header.header--compact {
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
  }
  #mobile-menu.open {
    transform: translateX(0);
  }
</style>

<script is:inline>
  (function() {
    function initMobileMenu() {
      var btn = document.getElementById('mobile-menu-btn');
      var menu = document.getElementById('mobile-menu');
      if (!btn || !menu) return;

      var menuIcon = btn.querySelector('.menu-icon');
      var closeIcon = btn.querySelector('.close-icon');

      btn.addEventListener('click', function() {
        var isOpen = menu.classList.contains('open');
        menu.classList.toggle('open');
        menu.setAttribute('aria-hidden', String(isOpen));
        btn.setAttribute('aria-expanded', String(!isOpen));
        menuIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
        document.body.style.overflow = isOpen ? '' : 'hidden';
      });

      // Close menu when clicking a link
      menu.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
          menu.classList.remove('open');
          menu.setAttribute('aria-hidden', 'true');
          btn.setAttribute('aria-expanded', 'false');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          document.body.style.overflow = '';
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMobileMenu);
    } else {
      initMobileMenu();
    }
  })();
</script>
