---
interface Props {
  subtitle?: string;
  label?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const { subtitle, label, align = 'center', light = false } = Astro.props;
---

<div class:list={['mb-12', align === 'center' ? 'text-center' : 'text-left']}>
  {label && (
    <span
      class:list={[
        'inline-block text-sm font-semibold tracking-wide uppercase mb-3',
        light ? 'text-white/60' : 'text-brand-primary',
      ]}
    >
      {label}
    </span>
  )}
  <h2
    class:list={[
      'font-serif text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight',
      light ? 'text-white' : 'text-brand-dark',
    ]}
  >
    <slot />
  </h2>
  {subtitle && (
    <p
      class:list={[
        'mt-4 text-lg max-w-2xl',
        align === 'center' ? 'mx-auto' : '',
        light ? 'text-white/70' : 'text-brand-muted',
      ]}
    >
      {subtitle}
    </p>
  )}
</div>
