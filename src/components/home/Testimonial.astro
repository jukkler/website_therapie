---
---

<section class="py-20 lg:py-28 bg-surface-bg">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <div class="bg-white rounded-2xl p-8 lg:p-12 shadow-sm">
        <div class="flex flex-col md:flex-row gap-8 items-center">
          <!-- Quote Icon -->
          <div class="shrink-0">
            <div class="w-20 h-20 rounded-full bg-brand-light flex items-center justify-center">
              <svg class="w-10 h-10 text-brand-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
              </svg>
            </div>
          </div>

          <!-- Quote Content -->
          <div class="text-center md:text-left">
            <blockquote class="font-serif text-xl sm:text-2xl text-brand-dark leading-relaxed italic">
              &ldquo;Ich bin rundum zufrieden. Auch mein Mann kommt regelmäßig in die Behandlung.
              Herr Ziesemer hört zu und geht auf alles ein. Es wird nichts Unnötiges, sondern nur
              Notwendiges unternommen und somit dem Schmerz Abhilfe geschaffen. Ich empfehle
              Herrn Ziesemer ruhigen Gewissens weiter.&rdquo;
            </blockquote>

            <div class="mt-6 flex flex-wrap items-center justify-center md:justify-start gap-3">
              <!-- Stars -->
              <div class="flex gap-1">
                {[1, 2, 3, 4, 5].map(() => (
                  <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="text-brand-muted text-sm font-medium">— Patientin via Google</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
